{
  "name": "portfolio",
  "version": "1.0.0",
  "description": "Portfolio website with Vue frontend and Node.js backend",
  "private": true,
  "type": "module",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w client\" \"npm run dev -w server\"",
    "build": "npm run build -w client",
    "preview": "npm run preview -w client",
    "start": "npm run start -w server",
    "client": "npm run dev -w client",
    "server": "npm run dev -w server"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
